{
  "name": "utcoder-vscode",
  "displayName": "UTcoder - AI Unit Test Generator",
  "description": "Right-click any source file to generate unit tests via the UTcoder server API. Supports Python, Java, C#, JavaScript, and TypeScript.",
  "version": "0.2.0",
  "publisher": "utcoder",
  "repository": {
    "type": "git",
    "url": "https://github.com/UTcoder/UTcoder"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Programming Languages"
  ],
  "keywords": [
    "unit test",
    "test generation",
    "AI",
    "pytest",
    "JUnit",
    "xUnit",
    "Jest"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onCommand:utcoder.generateTests"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "utcoder.generateTests",
        "title": "UTcoder: Generate Unit Tests"
      },
      {
        "command": "utcoder.checkHealth",
        "title": "UTcoder: Check Server Health"
      }
    ],
    "keybindings": [
      {
        "command": "utcoder.generateTests",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "utcoder.generateTests",
          "group": "utcoder@1",
          "when": "editorLangId =~ /^(python|java|csharp|javascript|typescript)$/"
        }
      ],
      "explorer/context": [
        {
          "command": "utcoder.generateTests",
          "group": "utcoder@1",
          "when": "resourceFilename =~ /(?i)\\.(py|java|cs|js|ts)$/"
        }
      ]
    }
  },
  "configuration": {
    "title": "UTcoder",
    "properties": {
      "utcoder.serverUrl": {
        "type": "string",
        "default": "http://localhost:8000",
        "description": "URL of the UTcoder HTTP server (e.g., http://localhost:8000)."
      },
      "utcoder.serverTimeout": {
        "type": "number",
        "default": 120000,
        "description": "Timeout in milliseconds for server requests."
      }
    }
  }
}
